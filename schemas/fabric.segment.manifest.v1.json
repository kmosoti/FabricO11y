{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabrico11y.dev/schemas/fabric.segment.manifest.v1.json",
  "title": "FabricO11y immutable segment manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "format_version",
    "segment_id",
    "created_at",
    "schema_set_id",
    "row_count",
    "frame_count",
    "ordering_bounds",
    "classifications",
    "compression",
    "integrity"
  ],
  "properties": {
    "api_version": {"const": "fabric.segment.manifest/v1"},
    "format_version": {"const": 1},
    "segment_id": {"type": "string", "pattern": "^seg-[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "schema_set_id": {"const": "fabric.evidence/v1"},
    "row_count": {"type": "integer", "minimum": 1, "maximum": 10000000},
    "frame_count": {"const": 1},
    "ordering_bounds": {"$ref": "#/$defs/orderingBounds"},
    "classifications": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$"}
    },
    "compression": {"$ref": "#/$defs/compression"},
    "integrity": {"$ref": "#/$defs/integrity"}
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "timeRange": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": {"$ref": "#/$defs/timestamp"},
            "max": {"$ref": "#/$defs/timestamp"}
          }
        },
        {"type": "null"}
      ]
    },
    "producerSequenceRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_id", "stream_id", "min", "max"],
      "properties": {
        "producer_id": {"$ref": "#/$defs/identifier"},
        "stream_id": {"$ref": "#/$defs/identifier"},
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": "integer", "minimum": 0}
      }
    },
    "logicalRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clock_id", "min", "max"],
      "properties": {
        "clock_id": {"$ref": "#/$defs/identifier"},
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": "integer", "minimum": 0}
      }
    },
    "orderingBounds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_sequences",
        "logical_clocks",
        "observed_at",
        "observed_by_at",
        "recorded_at"
      ],
      "properties": {
        "producer_sequences": {"type": "array", "items": {"$ref": "#/$defs/producerSequenceRange"}},
        "logical_clocks": {"type": "array", "items": {"$ref": "#/$defs/logicalRange"}},
        "observed_at": {"$ref": "#/$defs/timeRange"},
        "observed_by_at": {"$ref": "#/$defs/timeRange"},
        "recorded_at": {"$ref": "#/$defs/timeRange"}
      }
    },
    "dictionaryLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "version", "digest"],
      "properties": {
        "family": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$"},
        "version": {"type": "integer", "minimum": 1},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame_index", "payload_offset", "compressed_bytes", "uncompressed_bytes", "row_start", "row_count"],
      "properties": {
        "frame_index": {"const": 0},
        "payload_offset": {"const": 0},
        "compressed_bytes": {"type": "integer", "minimum": 1, "maximum": 268435456},
        "uncompressed_bytes": {"type": "integer", "minimum": 1, "maximum": 268435456},
        "row_start": {"const": 0},
        "row_count": {"type": "integer", "minimum": 1, "maximum": 10000000}
      }
    },
    "compression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["codec", "level", "dictionary", "frames"],
      "properties": {
        "codec": {"const": "zstd"},
        "level": {"type": "integer", "minimum": -7, "maximum": 22},
        "dictionary": {"oneOf": [{"$ref": "#/$defs/dictionaryLocator"}, {"type": "null"}]},
        "frames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {"$ref": "#/$defs/frame"}
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload_sha256", "content_sha256"],
      "properties": {
        "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
