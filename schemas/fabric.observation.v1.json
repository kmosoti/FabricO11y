{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabrico11y.dev/schemas/fabric.observation.v1.json",
  "title": "FabricO11y observation envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "observation_id",
    "epistemic_class",
    "interpretation",
    "producer",
    "observed_at",
    "observed_by_at",
    "recorded_at",
    "producer_sequence",
    "logical_time",
    "relations",
    "payload",
    "integrity",
    "classification",
    "origin",
    "attributes"
  ],
  "properties": {
    "api_version": {"const": "fabric.observation/v1"},
    "observation_id": {"$ref": "#/$defs/identifier"},
    "epistemic_class": {
      "enum": ["observed_fact", "derived_conclusion", "correlation", "assumption"]
    },
    "interpretation": {"$ref": "#/$defs/interpretation"},
    "producer": {"$ref": "#/$defs/producer"},
    "observed_at": {"$ref": "#/$defs/nullableTimestamp"},
    "observed_by_at": {"$ref": "#/$defs/timestamp"},
    "recorded_at": {"$ref": "#/$defs/timestamp"},
    "producer_sequence": {
      "oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]
    },
    "logical_time": {
      "oneOf": [{"$ref": "#/$defs/logicalTime"}, {"type": "null"}]
    },
    "relations": {"$ref": "#/$defs/relations"},
    "payload": true,
    "payload_ref": {"type": "string", "minLength": 1},
    "integrity": {"$ref": "#/$defs/integrity"},
    "classification": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$"},
    "origin": {"$ref": "#/$defs/origin"},
    "attributes": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"epistemic_class": {"const": "observed_fact"}}},
      "then": {"properties": {"interpretation": {"$ref": "#/$defs/observedFact"}}}
    },
    {
      "if": {"properties": {"epistemic_class": {"const": "derived_conclusion"}}},
      "then": {"properties": {"interpretation": {"$ref": "#/$defs/derivedConclusion"}}}
    },
    {
      "if": {"properties": {"epistemic_class": {"const": "correlation"}}},
      "then": {"properties": {"interpretation": {"$ref": "#/$defs/correlation"}}}
    },
    {
      "if": {"properties": {"epistemic_class": {"const": "assumption"}}},
      "then": {"properties": {"interpretation": {"$ref": "#/$defs/assumption"}}}
    }
  ],
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,255}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "nullableTimestamp": {
      "oneOf": [{"$ref": "#/$defs/timestamp"}, {"type": "null"}]
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_id", "stream_id"],
      "properties": {
        "producer_id": {"$ref": "#/$defs/identifier"},
        "stream_id": {"$ref": "#/$defs/identifier"}
      }
    },
    "logicalTime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clock_id", "counter"],
      "properties": {
        "clock_id": {"$ref": "#/$defs/identifier"},
        "counter": {"type": "integer", "minimum": 0}
      }
    },
    "relations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parents", "links", "correlations"],
      "properties": {
        "parents": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "links": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "correlations": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true}
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "digest"],
      "properties": {
        "algorithm": {"const": "sha256"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_id", "schema"],
      "properties": {
        "source_type": {"type": "string", "minLength": 1},
        "source_id": {"$ref": "#/$defs/identifier"},
        "schema": {"type": "string", "minLength": 1},
        "authority": {"type": ["string", "null"]}
      }
    },
    "observedFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {"kind": {"const": "observed_fact"}}
    },
    "derivedConclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "derivation_id", "input_ids"],
      "properties": {
        "kind": {"const": "derived_conclusion"},
        "derivation_id": {"$ref": "#/$defs/identifier"},
        "input_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        }
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "related_ids"],
      "properties": {
        "kind": {"const": "correlation"},
        "related_ids": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "statement"],
      "properties": {
        "kind": {"const": "assumption"},
        "statement": {"type": "string", "minLength": 1}
      }
    },
    "interpretation": {
      "oneOf": [
        {"$ref": "#/$defs/observedFact"},
        {"$ref": "#/$defs/derivedConclusion"},
        {"$ref": "#/$defs/correlation"},
        {"$ref": "#/$defs/assumption"}
      ]
    }
  }
}
